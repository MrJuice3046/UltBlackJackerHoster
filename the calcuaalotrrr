  html+='</tr>';
  const softLabels=['','A,2','A,3','A,4','A,5','A,6','A,7','A,8','A,9','A,10'];
  for(let t=13;t<=21;t++){
    html+=`<tr><td class="!text-left !pl-2 font-bold">${softLabels[t-12]||t}</td>`;
    for(let di=0;di<10;di++){
      const a=resolveAction(SOFT[t][di]);
      html+=`<td class="${ACTION_CSS[a]} rounded font-bold text-[11px]">${ACTION_SHORT[a]}</td>`;
    }
    html+='</tr>';
