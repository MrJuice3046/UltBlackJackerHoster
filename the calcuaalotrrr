======================================== */
function renderCardGrid(){
  const grid=document.getElementById('card-grid');
  grid.innerHTML='';
  for(let r=1;r<=13;r++){
    const rem=remaining(r);
    const tot=settings.numDecks*4;
    const pct=tot>0?rem/tot:0;
    const hilo=HI_LO(r);
    const hiloColor=hilo>0?'text-emerald-400':hilo<0?'text-red-400':'text-gray-500';
    const hiloBg=hilo>0?'bg-emerald-500':hilo<0?'bg-red-400':'bg-gray-500';
    const disabled=rem<=0;

    const el=document.createElement('div');
    el.className=`card-rank bg-casino-dark border border-casino-border rounded-lg p-1.5 sm:p-2 text-center ${disabled?'disabled':''}`;
    el.innerHTML=`
      <div class="text-base sm:text-lg font-bold leading-none mb-0.5">${RANK_NAME(r)}</div>
      <div class="${hiloColor} text-[9px] font-bold mb-1">${hilo>0?'+':''}${hilo}</div>
      <div class="text-[10px] tabular-nums text-casino-cream">${rem}<span class="text-casino-muted/50">/${tot}</span></div>
      <div class="h-1 bg-gray-800 rounded-full mt-1 overflow-hidden">
        <div class="fill-bar h-full ${hiloBg} rounded-full" style="width:${pct*100}%"></div>
      </div>
    `;
    el.addEventListener('click',e=>{e.preventDefault();addSeen(r)});
    el.addEventListener('contextmenu',e=>{e.preventDefault();removeSeen(r)});
    grid.appendChild(el);
  }
}

function addSeen(r){
  if(remaining(r)<=0)return;
  seenCards[r]++;
  cardHistory.push(r);
  updateAll();
}
function removeSeen(r){
  if(seenCards[r]<=0)return;
  seenCards[r]--;
  cardHistory.push(-r);
  updateAll();
}
function undoLast(){
  if(cardHistory.length===0)return;
  const last=cardHistory.pop();
  if(last>0)seenCards[last]--;
  else seenCards[-last]++;
  updateAll();
}
function resetShoe(){
  seenCards.fill(0);
  cardHistory=[];
  updateAll();
}

/* ========================================
   HAND ADVISOR UI
======================================== */
function setMode(mode){
  advisorMode=mode;
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.toggle('active',b.dataset.mode===mode));
