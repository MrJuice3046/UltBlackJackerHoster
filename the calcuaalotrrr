function showToast(msg){
  let toast=document.getElementById('toast');
  if(!toast){
    toast=document.createElement('div');
    toast.id='toast';
    toast.className='fixed bottom-6 left-1/2 -translate-x-1/2 bg-casino-dark border border-gold/30 text-casino-cream px-5 py-3 rounded-xl text-sm shadow-2xl z-50 transition-all duration-300 opacity-0 translate-y-4 pointer-events-none';
    document.body.appendChild(toast);
  }
  toast.textContent=msg;
  toast.classList.remove('opacity-0','translate-y-4');
  toast.classList.add('opacity-100','translate-y-0');
  clearTimeout(toast._timer);
  toast._timer=setTimeout(()=>{
    toast.classList.add('opacity-0','translate-y-4');
    toast.classList.remove('opacity-100','translate-y-0');
  },2000);
}

/* ========================================
   QUICK INPUT HANDLER
======================================== */
document.addEventListener('DOMContentLoaded',()=>{
  const input=document.getElementById('quick-input');
  input.addEventListener('keydown',e=>{
    if(e.key==='Enter'){
      e.preventDefault();
      const text=input.value.toUpperCase().replace(/[^A2-9TJQK]/g,'');
      if(!text)return;
      for(const ch of text){
        let r=null;
        if(ch==='A')r=1;
        else if(ch>='2'&&ch<='9')r=parseInt(ch);
        else if(ch==='T')r=10;
        else if(ch==='J')r=11;
        else if(ch==='Q')r=12;
        else if(ch==='K')r=13;
        if(r!==null&&remaining(r)>0){
          seenCards[r]++;
          cardHistory.push(r);
        }
      }
      input.value='';
      updateAll();
    }
  });
  // Also add on blur or paste
  input.addEventListener('paste',e=>{
    setTimeout(()=>{
      input.dispatchEvent(new KeyboardEvent('keydown',{key:'Enter'}));
    },50);
  });
});

/* ========================================
   KEYBOARD SHORTCUTS
======================================== */
document.addEventListener('keydown',e=>{
  if(e.target.tagName==='INPUT'||e.target.tagName==='SELECT')return;
  if(e.key==='z'&&(e.ctrlKey||e.metaKey)){e.preventDefault();undoLast()}
  if(e.key==='n'&&(e.ctrlKey||e.metaKey)){e.preventDefault();resetShoe()}
});

