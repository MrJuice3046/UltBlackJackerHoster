<style>
*{box-sizing:border-box}
body{background:#080c08;overflow-x:hidden}
.bg-atmo{position:fixed;inset:0;pointer-events:none;background:radial-gradient(ellipse at 30% 20%,rgba(13,74,46,.12) 0%,transparent 60%),radial-gradient(ellipse at 70% 80%,rgba(13,74,46,.08) 0%,transparent 50%),radial-gradient(ellipse at 50% 50%,rgba(201,168,76,.03) 0%,transparent 40%)}
.glow-gold{box-shadow:0 0 20px rgba(201,168,76,.15),inset 0 1px 0 rgba(201,168,76,.1)}
.glow-green{box-shadow:0 0 25px rgba(74,222,128,.2)}
.glow-red{box-shadow:0 0 25px rgba(239,68,68,.2)}
.card-rank{transition:all .15s ease;cursor:pointer;user-select:none;position:relative;overflow:hidden}
.card-rank:hover:not(.disabled){transform:translateY(-2px);box-shadow:0 4px 12px rgba(0,0,0,.4)}
.card-rank:active:not(.disabled){transform:scale(.95)}
.card-rank.disabled{opacity:.3;cursor:not-allowed;pointer-events:none}
.card-rank .fill-bar{transition:width .3s ease}
.slot-card{transition:all .2s ease;cursor:pointer}
.slot-card:hover{border-color:rgba(201,168,76,.5)}
.slot-card.active{border-color:#c9a84c;box-shadow:0 0 12px rgba(201,168,76,.3)}
.picker-btn{transition:all .12s ease;cursor:pointer}
.picker-btn:hover{background:rgba(201,168,76,.2);transform:scale(1.08)}
.picker-btn.selected{background:rgba(201,168,76,.3);border-color:#c9a84c}
.action-badge{animation:fadeSlideIn .3s ease}
@keyframes fadeSlideIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
@keyframes pulse-glow{0%,100%{box-shadow:0 0 15px rgba(201,168,76,.2)}50%{box-shadow:0 0 30px rgba(201,168,76,.4)}}
.pulse-border{animation:pulse-glow 2s ease-in-out infinite}
.edge-bar-fill{transition:all .6s cubic-bezier(.4,0,.2,1)}
.prob-bar{transition:width .4s ease}
.tab-btn{transition:all .15s ease}
.tab-btn.active{background:rgba(201,168,76,.15);color:#c9a84c;border-color:rgba(201,168,76,.3)}
.charts-grid td,.charts-grid th{padding:4px 6px;text-align:center;font-size:12px;border:1px solid rgba(26,51,34,.6)}
.charts-grid th{background:rgba(201,168,76,.1);color:#c9a84c;font-weight:600}
::-webkit-scrollbar{width:6px;height:6px}
::-webkit-scrollbar-track{background:#0a0e0a}
::-webkit-scrollbar-thumb{background:#1a3322;border-radius:3px}
::-webkit-scrollbar-thumb:hover{background:#2a5035}
@media(prefers-reduced-motion:reduce){*{animation:none!important;transition:none!important}}
</style>
</head>
<body class="min-h-screen font-sans text-casino-cream">
<div class="bg-atmo"></div>

<div class="relative z-10 max-w-7xl mx-auto px-3 sm:px-6 py-4 sm:py-6">

<!-- Header -->
<header class="text-center mb-6 sm:mb-8">
  <h1 class="font-display text-3xl sm:text-4xl md:text-5xl font-black text-gold tracking-tight leading-tight">
    Blackjack Advantage Engine
  </h1>
  <p class="text-casino-muted mt-1.5 text-xs sm:text-sm tracking-[.25em] uppercase">
    Hi-Lo Count System &middot; Optimal Strategy &middot; Kelly Bet Sizing
  </p>
</header>

<!-- Count Dashboard -->
<section class="grid grid-cols-2 lg:grid-cols-5 gap-3 mb-6" id="dash">
  <div class="bg-casino-panel border border-casino-border rounded-xl p-3 sm:p-4 glow-gold">
    <div class="text-casino-muted text-[10px] uppercase tracking-widest mb-1">Running Count</div>
    <div class="text-2xl sm:text-3xl font-bold tabular-nums" id="rc-display">0</div>
  </div>
  <div class="bg-casino-panel border border-casino-border rounded-xl p-3 sm:p-4">
    <div class="text-casino-muted text-[10px] uppercase tracking-widest mb-1">True Count</div>
    <div class="text-2xl sm:text-3xl font-bold tabular-nums" id="tc-display">0.0</div>
  </div>
  <div class="bg-casino-panel border border-casino-border rounded-xl p-3 sm:p-4">
    <div class="text-casino-muted text-[10px] uppercase tracking-widest mb-1">Decks Remaining</div>
    <div class="text-2xl sm:text-3xl font-bold tabular-nums" id="dr-display">6.0</div>
  </div>
  <div class="bg-casino-panel border border-casino-border rounded-xl p-3 sm:p-4">
    <div class="text-casino-muted text-[10px] uppercase tracking-widest mb-1">Player Edge</div>
    <div class="text-2xl sm:text-3xl font-bold tabular-nums" id="edge-display">-0.45%</div>
  </div>
  <div class="col-span-2 lg:col-span-1 bg-casino-panel border border-casino-border rounded-xl p-3 sm:p-4">
    <div class="text-casino-muted text-[10px] uppercase tracking-widest mb-1">Penetration</div>
    <div class="text-2xl sm:text-3xl font-bold tabular-nums" id="pen-display">0%</div>
    <div class="h-1.5 bg-gray-800 rounded-full mt-2 overflow-hidden">
      <div class="h-full bg-gold rounded-full transition-all duration-300" id="pen-bar" style="width:0%"></div>
    </div>
  </div>
</section>

<!-- Edge Meter -->
<div class="bg-casino-panel border border-casino-border rounded-xl p-4 mb-6">
  <div class="flex justify-between text-[10px] text-casino-muted uppercase tracking-widest mb-2">
    <span>House Edge</span><span>Neutral</span><span>Player Edge</span>
  </div>
  <div class="h-4 bg-gray-800/80 rounded-full overflow-hidden relative">
    <div class="absolute inset-y-0 left-1/2 w-px bg-casino-muted/40 z-10"></div>
    <div class="edge-bar-fill h-full rounded-full absolute top-0" id="edge-bar" style="left:50%;width:0%;background:#ef4444"></div>
  </div>
  <div class="flex justify-between text-[9px] text-casino-muted/50 mt-1 tabular-nums">
    <span>-2%</span><span>-1%</span><span>0%</span><span>+1%</span><span>+2%</span>
  </div>
</div>

<!-- Main Grid -->
<div class="grid grid-cols-1 lg:grid-cols-5 gap-5 mb-6">

  <!-- Card Tracker -->
  <section class="lg:col-span-2 bg-casino-panel border border-casino-border rounded-xl p-4">
    <div class="flex items-center justify-between mb-3">
      <h2 class="font-display text-lg text-gold">Card Tracker</h2>
      <div class="flex gap-2">
        <button onclick="undoLast()" class="text-xs px-2.5 py-1 rounded-lg bg-casino-dark border border-casino-border text-casino-muted hover:text-casino-cream transition-colors" title="Undo last card">
          <i class="fa-solid fa-rotate-left mr-1"></i>Undo
        </button>
        <button onclick="resetShoe()" class="text-xs px-2.5 py-1 rounded-lg bg-casino-dark border border-casino-border text-casino-muted hover:text-casino-cream transition-colors">
          <i class="fa-solid fa-arrows-rotate mr-1"></i>New Shoe
        </button>
      </div>
    </div>

    <!-- Quick Input -->
    <div class="mb-3">
      <input type="text" id="quick-input" placeholder="Quick add: A235TQK..."
        class="w-full bg-casino-dark border border-casino-border rounded-lg px-3 py-2 text-sm text-casino-cream placeholder-casino-muted/50 focus:outline-none focus:border-gold/50 transition-colors font-mono tracking-wider">
      <div class="text-[9px] text-casino-muted/40 mt-1">A=Ace, 2-9, T=10, J, Q, K &middot; Left-click card to add, right-click to remove</div>
    </div>

    <!-- Card Grid -->
    <div class="grid grid-cols-7 gap-1.5 sm:gap-2" id="card-grid"></div>

    <!-- Count Legend -->
    <div class="flex items-center justify-center gap-4 mt-3 text-[10px] text-casino-muted">
      <span><span class="inline-block w-2 h-2 rounded-full bg-emerald-500 mr-1"></span>+1 (2-6)</span>
      <span><span class="inline-block w-2 h-2 rounded-full bg-gray-500 mr-1"></span>0 (7-9)</span>
      <span><span class="inline-block w-2 h-2 rounded-full bg-red-400 mr-1"></span>-1 (10-A)</span>
    </div>
  </section>

  <!-- Hand Advisor -->
  <section class="lg:col-span-3 space-y-4">
    <!-- Mode Toggle -->
    <div class="bg-casino-panel border border-casino-border rounded-xl p-4">
      <div class="flex items-center gap-2 mb-3">
        <h2 class="font-display text-lg text-gold">Hand Advisor</h2>
        <div class="flex ml-auto bg-casino-dark rounded-lg border border-casino-border overflow-hidden">
          <button class="tab-btn active text-xs px-3 py-1.5 border-r border-casino-border" data-mode="card" onclick="setMode('card')">Cards</button>
          <button class="tab-btn text-xs px-3 py-1.5" data-mode="total" onclick="setMode('total')">Total</button>
        </div>
      </div>

      <!-- Card Mode -->
      <div id="card-mode">
        <div class="flex flex-wrap gap-3 mb-3">
          <div class="flex-1 min-w-[100px]">
            <div class="text-[10px] text-casino-muted uppercase tracking-widest mb-1">Your Hand</div>
            <div class="flex gap-2">
              <div class="slot-card w-14 h-20 bg-casino-dark border-2 border-casino-border rounded-lg flex items-center justify-center text-xl font-bold" id="slot-p1" onclick="selectSlot('p1')">?</div>
              <div class="slot-card w-14 h-20 bg-casino-dark border-2 border-casino-border rounded-lg flex items-center justify-center text-xl font-bold" id="slot-p2" onclick="selectSlot('p2')">?</div>
            </div>
          </div>
          <div class="min-w-[70px]">
            <div class="text-[10px] text-casino-muted uppercase tracking-widest mb-1">Dealer</div>
            <div class="slot-card w-14 h-20 bg-casino-dark border-2 border-casino-border rounded-lg flex items-center justify-center text-xl font-bold" id="slot-d" onclick="selectSlot('d')">?</div>
          </div>
        </div>
        <div class="text-[10px] text-casino-muted uppercase tracking-widest mb-1.5">Select a slot above, then pick a card:</div>
        <div class="grid grid-cols-13 gap-1" id="card-picker"></div>
      </div>

      <!-- Total Mode -->
      <div id="total-mode" class="hidden">
        <div class="grid grid-cols-2 gap-4 mb-3">
          <div>
            <label class="text-[10px] text-casino-muted uppercase tracking-widest mb-1 block">Your Total</label>
            <input type="number" min="4" max="21" id="total-input" value="16"
              class="w-full bg-casino-dark border border-casino-border rounded-lg px-3 py-2.5 text-xl font-bold text-casino-cream focus:outline-none focus:border-gold/50 transition-colors tabular-nums">
          </div>
          <div>
            <label class="text-[10px] text-casino-muted uppercase tracking-widest mb-1 block">Dealer Upcard</label>
            <select id="dealer-select" class="w-full bg-casino-dark border border-casino-border rounded-lg px-3 py-2.5 text-xl font-bold text-casino-cream focus:outline-none focus:border-gold/50 transition-colors appearance-none cursor-pointer">
              <option value="2">2</option><option value="3">3</option><option value="4">4</option>
              <option value="5">5</option><option value="6">6</option><option value="7">7</option>
              <option value="8">8</option><option value="9">9</option><option value="10">10</option>
              <option value="1">Ace</option>
            </select>
          </div>
        </div>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" id="soft-check" class="w-4 h-4 rounded accent-gold">
          <span class="text-sm text-casino-muted">Soft hand (contains Ace counted as 11)</span>
        </label>
      </div>

      <button onclick="calculateAdvice()" class="mt-4 w-full py-3 bg-gradient-to-r from-gold-dark to-gold text-casino-black font-bold rounded-xl hover:from-gold hover:to-gold-light transition-all text-sm tracking-wider uppercase">
        <i class="fa-solid fa-calculator mr-2"></i>Calculate Optimal Play
      </button>
    </div>

    <!-- Results -->
    <div id="results-panel" class="hidden space-y-4">
      <!-- Main Recommendation -->
      <div class="bg-casino-panel border-2 rounded-xl p-5 text-center" id="rec-card">
        <div class="text-[10px] text-casino-muted uppercase tracking-widest mb-2">Optimal Play</div>
        <div class="text-4xl sm:text-5xl font-black mb-1" id="rec-action">STAND</div>
        <div class="text-sm text-casino-muted" id="rec-ev">EV: +0.00%</div>
      </div>

      <!-- Deviation Alert -->
      <div class="hidden bg-casino-panel border border-gold/30 rounded-xl p-4" id="deviation-alert">
        <div class="flex items-start gap-3">
          <i class="fa-solid fa-bolt text-gold mt-0.5"></i>
          <div>
            <div class="text-xs font-bold text-gold uppercase tracking-wider">Count Deviation Active</div>
            <div class="text-sm text-casino-cream mt-1" id="deviation-text"></div>
          </div>
        </div>
      </div>

      <!-- Probabilities -->
      <div class="bg-casino-panel border border-casino-border rounded-xl p-4">
        <div class="text-[10px] text-casino-muted uppercase tracking-widest mb-3">Win Probability (Simulation)</div>
        <div class="space-y-2.5">
          <div>
            <div class="flex justify-between text-xs mb-0.5"><span class="text-emerald-400">Win</span><span class="tabular-nums" id="prob-win">0%</span></div>
            <div class="h-2.5 bg-gray-800 rounded-full overflow-hidden"><div class="prob-bar h-full bg-emerald-500 rounded-full" id="bar-win" style="width:0%"></div></div>
          </div>
          <div>
            <div class="flex justify-between text-xs mb-0.5"><span class="text-red-400">Lose</span><span class="tabular-nums" id="prob-lose">0%</span></div>
            <div class="h-2.5 bg-gray-800 rounded-full overflow-hidden"><div class="prob-bar h-full bg-red-500 rounded-full" id="bar-lose" style="width:0%"></div></div>
          </div>
          <div>
            <div class="flex justify-between text-xs mb-0.5"><span class="text-slate-400">Push</span><span class="tabular-nums" id="prob-push">0%</span></div>
            <div class="h-2.5 bg-gray-800 rounded-full overflow-hidden"><div class="prob-bar h-full bg-slate-500 rounded-full" id="bar-push" style="width:0%"></div></div>
          </div>
        </div>
        <div class="text-[9px] text-casino-muted/40 mt-2" id="sim-info"></div>
      </div>

      <!-- Action Comparison -->
      <div class="bg-casino-panel border border-casino-border rounded-xl p-4">
        <div class="text-[10px] text-casino-muted uppercase tracking-widest mb-3">Action Comparison (EV per unit)</div>
        <div class="space-y-2" id="ev-comparison"></div>
      </div>

      <!-- Bet Sizing -->
      <div class="bg-casino-panel border border-casino-border rounded-xl p-4">
        <div class="text-[10px] text-casino-muted uppercase tracking-widest mb-3">Kelly Criterion Bet Sizing</div>
        <div class="grid grid-cols-3 gap-3">
          <div class="text-center">
            <div class="text-[10px] text-casino-muted mb-1">1/4 Kelly</div>
            <div class="text-lg font-bold text-gold tabular-nums" id="bet-quarter">$0</div>
          </div>
          <div class="text-center">
            <div class="text-[10px] text-casino-muted mb-1">1/2 Kelly</div>
            <div class="text-lg font-bold text-gold tabular-nums" id="bet-half">$0</div>
          </div>
          <div class="text-center">
            <div class="text-[10px] text-casino-muted mb-1">Full Kelly</div>
            <div class="text-lg font-bold text-gold tabular-nums" id="bet-full">$0</div>
          </div>
        </div>
        <div class="text-[9px] text-casino-muted/40 mt-2">Based on bankroll: $<span id="bankroll-display">1000</span></div>
      </div>

      <!-- Insurance -->
      <div class="hidden bg-casino-panel border border-casino-border rounded-xl p-4" id="insurance-panel">
        <div class="flex items-center gap-3">
          <i class="fa-solid fa-shield-halved text-lg" id="insurance-icon"></i>
          <div>
            <div class="font-bold text-sm" id="insurance-text">Insurance</div>
            <div class="text-xs text-casino-muted" id="insurance-detail"></div>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>

<!-- Rules Config -->
<section class="bg-casino-panel border border-casino-border rounded-xl p-4 mb-6">
  <h2 class="font-display text-lg text-gold mb-3">Game Rules</h2>
  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3">
    <div>
      <label class="text-[10px] text-casino-muted uppercase tracking-widest mb-1 block">Decks</label>
      <select id="cfg-decks" onchange="onRulesChange()" class="w-full bg-casino-dark border border-casino-border rounded-lg px-3 py-2 text-sm text-casino-cream focus:outline-none focus:border-gold/50 appearance-none cursor-pointer">
        <option value="1">1 Deck</option><option value="2">2 Decks</option><option value="4">4 Decks</option>
        <option value="6" selected>6 Decks</option><option value="8">8 Decks</option>
      </select>
    </div>
    <div>
      <label class="text-[10px] text-casino-muted uppercase tracking-widest mb-1 block">Soft 17</label>
      <select id="cfg-s17" onchange="onRulesChange()" class="w-full bg-casino-dark border border-casino-border rounded-lg px-3 py-2 text-sm text-casino-cream focus:outline-none focus:border-gold/50 appearance-none cursor-pointer">
        <option value="1" selected>Dealer Stands</option><option value="0">Dealer Hits</option>
      </select>
    </div>
    <div>
      <label class="text-[10px] text-casino-muted uppercase tracking-widest mb-1 block">Double After Split</label>
      <select id="cfg-das" onchange="onRulesChange()" class="w-full bg-casino-dark border border-casino-border rounded-lg px-3 py-2 text-sm text-casino-cream focus:outline-none focus:border-gold/50 appearance-none cursor-pointer">
        <option value="1" selected>Allowed</option><option value="0">Not Allowed</option>
      </select>
    </div>
    <div>
      <label class="text-[10px] text-casino-muted uppercase tracking-widest mb-1 block">Surrender</label>
      <select id="cfg-sur" onchange="onRulesChange()" class="w-full bg-casino-dark border border-casino-border rounded-lg px-3 py-2 text-sm text-casino-cream focus:outline-none focus:border-gold/50 appearance-none cursor-pointer">
        <option value="1" selected>Late Surrender</option><option value="0">No Surrender</option>
      </select>
    </div>
    <div>
      <label class="text-[10px] text-casino-muted uppercase tracking-widest mb-1 block">Bankroll ($)</label>
      <input type="number" id="cfg-bankroll" value="1000" min="100" step="100" onchange="onRulesChange()"
        class="w-full bg-casino-dark border border-casino-border rounded-lg px-3 py-2 text-sm text-casino-cream focus:outline-none focus:border-gold/50 tabular-nums">
    </div>
  </div>
</section>

<!-- Strategy Chart -->
<section class="bg-casino-panel border border-casino-border rounded-xl overflow-hidden mb-8">
  <button onclick="toggleChart()" class="w-full flex items-center justify-between p-4 text-left hover:bg-casino-dark/50 transition-colors" id="chart-toggle">
    <h2 class="font-display text-lg text-gold">Basic Strategy Reference Chart</h2>
    <i class="fa-solid fa-chevron-down text-casino-muted transition-transform" id="chart-arrow"></i>
  </button>
  <div class="hidden px-4 pb-4 overflow-x-auto" id="chart-body">
    <div class="text-[10px] text-casino-muted mb-2 flex gap-4 flex-wrap">
      <span><span class="inline-block w-3 h-3 rounded bg-red-400/80 align-middle mr-1"></span>Hit</span>
      <span><span class="inline-block w-3 h-3 rounded bg-blue-400/80 align-middle mr-1"></span>Stand</span>
      <span><span class="inline-block w-3 h-3 rounded bg-yellow-400/80 align-middle mr-1"></span>Double</span>
      <span><span class="inline-block w-3 h-3 rounded bg-emerald-400/80 align-middle mr-1"></span>Split</span>
      <span><span class="inline-block w-3 h-3 rounded bg-orange-400/80 align-middle mr-1"></span>Surrender</span>
      <span><span class="inline-block w-3 h-3 rounded bg-purple-400/80 align-middle mr-1"></span>Insurance</span>
    </div>
    <div id="strategy-charts" class="space-y-4"></div>
  </div>
</section>

<footer class="text-center text-[10px] text-casino-muted/30 pb-4">
  For educational purposes only. Card counting is legal but casinos may refuse service.
</footer>
</div>

<script>
/* ========================================
   ACTION CONSTANTS
======================================== */
const HIT=0,STAND=1,DOUBLE=2,SPLIT=3,SURRENDER=4,Dh=5,Ds=6,Rh=7,Rs=8,Ph=9,Rp=10;
const ACTION_NAMES=['HIT','STAND','DOUBLE','SPLIT','SURRENDER','Dbl/Hit','Dbl/Stand','Sur/Hit','Sur/Stand','Spl/Hit','Spl/Sur'];
const ACTION_SHORT=['H','S','D','P','R','Dh','Ds','Rh','Rs','Ph','Rp'];
const ACTION_CSS=['bg-red-400/80 text-casino-black','bg-blue-400/80 text-casino-black','bg-yellow-400/80 text-casino-black','bg-emerald-400/80 text-casino-black','bg-orange-400/80 text-casino-black','bg-yellow-400/80 text-casino-black','bg-yellow-400/80 text-casino-black','bg-orange-400/80 text-casino-black','bg-orange-400/80 text-casino-black','bg-emerald-400/80 text-casino-black','bg-orange-400/80 text-casino-black'];

/* ========================================
   BASIC STRATEGY TABLES (S17, DAS, LS)
   Index: dealer 2=0,3=1,4=2,5=3,6=4,7=5,8=6,9=7,10=8,A=9
======================================== */
const HARD=[
  null,null,null,null,
  [HIT,HIT,HIT,HIT,HIT,HIT,HIT,HIT,HIT,HIT],//4
  [HIT,HIT,HIT,HIT,HIT,HIT,HIT,HIT,HIT,HIT],//5
