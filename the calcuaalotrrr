<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Blackjack Advantage Engine</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<script src="https://cdn.tailwindcss.com"></script>
<script>
tailwind.config={theme:{extend:{colors:{felt:'#0d4a2e','felt-dark':'#082a1a',gold:'#c9a84c','gold-light':'#e5cc7a','gold-dark':'#8a7233',casino:{black:'#080c08',dark:'#0f1f14',green:'#0d4a2e',cream:'#e2ddd0',muted:'#6b7a6e',border:'#1a3322',red:'#ef4444',panel:'#111e15'}},fontFamily:{display:['Playfair Display','serif'],sans:['DM Sans','sans-serif']}}}}
