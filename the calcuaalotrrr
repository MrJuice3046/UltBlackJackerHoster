  const edge=playerEdge();

  const rcEl=document.getElementById('rc-display');
  rcEl.textContent=(rc>0?'+':'')+rc;
  rcEl.className='text-2xl sm:text-3xl font-bold tabular-nums '+(rc>0?'text-emerald-400':rc<0?'text-red-400':'text-casino-cream');

  const tcEl=document.getElementById('tc-display');
  tcEl.textContent=(tc>0?'+':'')+tc.toFixed(1);
  tcEl.className='text-2xl sm:text-3xl font-bold tabular-nums '+(tc>0?'text-emerald-400':tc<0?'text-red-400':'text-casino-cream');

  document.getElementById('dr-display').textContent=dr.toFixed(1);
  document.getElementById('pen-display').textContent=(pen*100).toFixed(0)+'%';
  document.getElementById('pen-bar').style.width=(pen*100)+'%';

  const edgeStr=(edge>0?'+':'')+edge.toFixed(2)+'%';
  const edgeEl=document.getElementById('edge-display');
  edgeEl.textContent=edgeStr;
  edgeEl.className='text-2xl sm:text-3xl font-bold tabular-nums '+(edge>0?'text-emerald-400':edge<0?'text-red-400':'text-casino-cream');

  // Edge bar
  const bar=document.getElementById('edge-bar');
  const clampedEdge=Math.max(-2,Math.min(2,edge));
  const scale=25; // 1% = 25% of bar
  if(clampedEdge>=0){
    bar.style.left='50%';
    bar.style.width=(clampedEdge*scale)+'%';
    bar.style.background='#4ade80';
  } else {
    bar.style.left=(50+clampedEdge*scale)+'%';
    bar.style.width=(-clampedEdge*scale)+'%';
    bar.style.background='#f87171';
  }
}

