function selectSlot(slot){
  selectedSlot=slot;
  document.querySelectorAll('.slot-card').forEach(el=>el.classList.remove('active'));
  document.getElementById('slot-'+slot).classList.add('active');
  updatePickerHighlight();
}

function pickCard(r){
  if(!selectedSlot)return;
  if(selectedSlot==='p1'){playerCards[0]=r;document.getElementById('slot-p1').textContent=RANK_NAME(r)}
  else if(selectedSlot==='p2'){playerCards[1]=r;document.getElementById('slot-p2').textContent=RANK_NAME(r)}
  else if(selectedSlot==='d'){dealerCard=r;document.getElementById('slot-d').textContent=RANK_NAME(r)}
  updatePickerHighlight();
}

function updatePickerHighlight(){
  document.querySelectorAll('.picker-btn').forEach(btn=>{
    const r=parseInt(btn.dataset.rank);
    const isP1=playerCards[0]===r;
    const isP2=playerCards[1]===r;
    const isD=dealerCard===r;
    btn.classList.toggle('selected',selectedSlot==='p1'&&isP1||selectedSlot==='p2'&&isP2||selectedSlot==='d'&&isD);
  });
}

function clearSlots(){
  playerCards=[null,null];dealerCard=null;selectedSlot=null;
  document.getElementById('slot-p1').textContent='?';
  document.getElementById('slot-p2').textContent='?';
  document.getElementById('slot-d').textContent='?';
  document.querySelectorAll('.slot-card').forEach(el=>el.classList.remove('active'));
  updatePickerHighlight();
}

/* ========================================
   CALCULATE ADVICE
======================================== */
let calcTimeout=null;
function calculateAdvice(){
  clearTimeout(calcTimeout);
  calcTimeout=setTimeout(_calculateAdvice,50);
}

function _calculateAdvice(){
  let pCards,total,soft,isPair=false,pairRank,dealerUpcard;

  if(advisorMode==='card'){
    if(playerCards[0]===null||playerCards[1]===null||dealerCard===null){
      showToast('Select all cards first');return;
    }
    pCards=[playerCards[0],playerCards[1]];
    // Normalize 10-value cards for pair detection
    const v1=playerCards[0]>=10?10:playerCards[0];
    const v2=playerCards[1]>=10?10:playerCards[1];
    isPair=v1===v2;
    pairRank=v1;
    total=handTotal(pCards);
    soft=isSoft(pCards);
    dealerUpcard=dealerCard;
  } else {
    total=parseInt(document.getElementById('total-input').value);
    soft=document.getElementById('soft-check').checked;
    dealerUpcard=parseInt(document.getElementById('dealer-select').value);
    pCards=null; // no specific cards in total mode
    isPair=false;pairRank=undefined;
    if(isNaN(total)||total<4||total>21){showToast('Enter a valid total (4-21)');return}
  }

  const tc=trueCount();
  const edge=playerEdge();

  // Get basic strategy action
  const basicAction=getBasicStrategy(total,soft,isPair,pairRank,dealerUpcard);

  // Check for deviations
  const deviation=checkDeviation(total,soft,isPair,pairRank,dealerUpcard,tc);
  const finalAction=deviation?deviation.action:basicAction;

  // Check insurance
  const showInsurance=dealerUpcard===1;
  const takeInsurance=tc>=3;

  // Show results panel
  document.getElementById('results-panel').classList.remove('hidden');

  // Main recommendation
  const recEl=document.getElementById('rec-action');
  const recCard=document.getElementById('rec-card');
  recEl.textContent=ACTION_NAMES[finalAction];
  recEl.className='text-4xl sm:text-5xl font-black mb-1 action-badge '+getActionTextClass(finalAction);
  recCard.className='bg-casino-panel border-2 rounded-xl p-5 text-center '+(finalAction===STAND||finalAction===DOUBLE||finalAction===SPLIT?'glow-green':'glow-red');

  // Run simulations for EV
  const simCards=pCards||generateCardsForTotal(total,soft);
  const numSims=4000;
  let simResults=null;
  let comparisonData=[];

  // Simulate the recommended action (skip split for sim)
  if(finalAction!==SPLIT){
    simResults=simulateAction(simCards,dealerUpcard,finalAction,numSims);
  }

  // Simulate other actions for comparison
  const validActions=[HIT,STAND];
  if(simCards.length===2)validActions.push(DOUBLE);
  if(isPair&&simCards.length===2)validActions.push(SPLIT);
  if(settings.surrender)validActions.push(SURRENDER);

  for(const act of validActions){
    if(act===SPLIT){
      comparisonData.push({action:SPLIT,ev:null,winRate:null,lossRate:null,pushRate:null});
      continue;
    }
    const res=simulateAction(simCards,dealerUpcard,act,numSims);
    if(res)comparisonData.push({action:act,...res});
  }

  // Display EV
  let evText;
  if(finalAction===SPLIT){
    evText='EV: Higher than alternatives (split simulation complex)';
    document.getElementById('rec-ev').textContent=evText;
  } else if(simResults){
    document.getElementById('rec-ev').textContent=`EV: ${(simResults.ev*100).toFixed(2)}%`;
  }

  // Probabilities
  if(simResults){
    document.getElementById('prob-win').textContent=(simResults.winRate*100).toFixed(1)+'%';
    document.getElementById('prob-lose').textContent=(simResults.lossRate*100).toFixed(1)+'%';
    document.getElementById('prob-push').textContent=(simResults.pushRate*100).toFixed(1)+'%';
    document.getElementById('bar-win').style.width=(simResults.winRate*100)+'%';
    document.getElementById('bar-lose').style.width=(simResults.lossRate*100)+'%';
    document.getElementById('bar-push').style.width=(simResults.pushRate*100)+'%';
    document.getElementById('sim-info').textContent=`Based on ${numSims} Monte Carlo simulations with current deck composition`;
  } else {
    document.getElementById('prob-win').textContent='—';
    document.getElementById('prob-lose').textContent='—';
    document.getElementById('prob-push').textContent='—';
    document.getElementById('bar-win').style.width='0%';
    document.getElementById('bar-lose').style.width='0%';
    document.getElementById('bar-push').style.width='0%';
    document.getElementById('sim-info').textContent='Split probability requires complex multi-hand simulation';
  }

  // Action comparison
  const compEl=document.getElementById('ev-comparison');
  compEl.innerHTML='';
  // Sort by EV descending
  const sorted=[...comparisonData].sort((a,b)=>(b.ev||0)-(a.ev||0));
  for(const item of sorted){
    const isRec=item.action===finalAction;
    const evStr=item.ev!==null?(item.ev*100).toFixed(2)+'%':'N/A';
    const barW=item.ev!==null?Math.min(Math.max((item.ev+0.5)*50,2),100):0;
    const barColor=item.ev>0?'bg-emerald-500':item.ev<0?'bg-red-500':'bg-gray-500';
    const div=document.createElement('div');
    div.className=`flex items-center gap-2 ${isRec?'':'opacity-60'}`;
    div.innerHTML=`
      <div class="w-10 text-xs font-bold ${getActionTextClass(item.action)}">${ACTION_SHORT[item.action]}</div>
      <div class="flex-1 h-2.5 bg-gray-800 rounded-full overflow-hidden">
        <div class="h-full ${barColor} rounded-full transition-all duration-500" style="width:${barW}%"></div>
      </div>
      <div class="w-16 text-right text-xs tabular-nums font-mono ${item.ev>0?'text-emerald-400':item.ev<0?'text-red-400':'text-gray-400'}">${evStr}</div>
      ${isRec?'<i class="fa-solid fa-check text-gold text-xs w-4"></i>':'<div class="w-4"></div>'}
    `;
    compEl.appendChild(div);
  }

  // Deviation alert
  const devEl=document.getElementById('deviation-alert');
  if(deviation){
    devEl.classList.remove('hidden');
    document.getElementById('deviation-text').textContent=
      `${deviation.desc} — Basic strategy says ${ACTION_NAMES[deviation.basic]}, but at TC ${tc.toFixed(1)}, ${ACTION_NAMES[deviation.action]} is optimal.`;
  } else {
    devEl.classList.add('hidden');
  }

  // Bet sizing
  const kelly=edge/1.26; // variance ~1.26 for blackjack
  const bankroll=settings.bankroll;
  document.getElementById('bet-quarter').textContent='$'+Math.max(0,Math.round(kelly*0.25*bankroll));
  document.getElementById('bet-half').textContent='$'+Math.max(0,Math.round(kelly*0.5*bankroll));
  document.getElementById('bet-full').textContent='$'+Math.max(0,Math.round(kelly*bankroll));

  // Insurance
  const insEl=document.getElementById('insurance-panel');
  if(showInsurance){
    insEl.classList.remove('hidden');
    const insIcon=document.getElementById('insurance-icon');
    const insText=document.getElementById('insurance-text');
    const insDetail=document.getElementById('insurance-detail');
    if(takeInsurance){
      insIcon.className='fa-solid fa-shield-halved text-lg text-emerald-400';
      insText.textContent='Take Insurance';
      insText.className='font-bold text-sm text-emerald-400';
      insDetail.textContent=`True count ${tc.toFixed(1)} ≥ 3.0 — Positive EV insurance bet.`;
    } else {
      insIcon.className='fa-solid fa-shield-halved text-lg text-red-400';
      insText.textContent='Decline Insurance';
      insText.className='font-bold text-sm text-red-400';
      insDetail.textContent=`True count ${tc.toFixed(1)} < 3.0 — Negative EV insurance bet.`;
    }
  } else {
    insEl.classList.add('hidden');
  }
}

function generateCardsForTotal(total,soft){
  // Generate a plausible 2-card hand for the given total
  if(soft){
    const other=total-11; // Ace = 11, other card makes up the rest
    return[1, other>=10?10:other];
  }
  // Hard total - generate two cards that sum to total
  // Simple: use total-10 and 10 for totals >= 12, otherwise total-2 and 2
  if(total>=12){
    const first=Math.min(total-10,10);
    return[first>=10?10:first, 10];
  }
  return[Math.max(total-2,2), 2];
}

function getActionTextClass(action){
  switch(action){
    case HIT:return 'text-red-400';
    case STAND:return 'text-blue-400';
    case DOUBLE:return 'text-yellow-400';
    case SPLIT:return 'text-emerald-400';
    case SURRENDER:return 'text-orange-400';
    default:return 'text-casino-cream';
  }
}

/* ========================================
   DASHBOARD UPDATE
======================================== */
function updateDashboard(){
  const rc=runningCount();
  const tc=trueCount();
  const dr=decksRemaining();
  const pen=penetration();
  const edge=playerEdge();

  const rcEl=document.getElementById('rc-display');
  rcEl.textContent=(rc>0?'+':'')+rc;
  rcEl.className='text-2xl sm:text-3xl font-bold tabular-nums '+(rc>0?'text-emerald-400':rc<0?'text-red-400':'text-casino-cream');

  const tcEl=document.getElementById('tc-display');
  tcEl.textContent=(tc>0?'+':'')+tc.toFixed(1);
  tcEl.className='text-2xl sm:text-3xl font-bold tabular-nums '+(tc>0?'text-emerald-400':tc<0?'text-red-400':'text-casino-cream');

  document.getElementById('dr-display').textContent=dr.toFixed(1);
  document.getElementById('pen-display').textContent=(pen*100).toFixed(0)+'%';
  document.getElementById('pen-bar').style.width=(pen*100)+'%';

  const edgeStr=(edge>0?'+':'')+edge.toFixed(2)+'%';
  const edgeEl=document.getElementById('edge-display');
  edgeEl.textContent=edgeStr;
  edgeEl.className='text-2xl sm:text-3xl font-bold tabular-nums '+(edge>0?'text-emerald-400':edge<0?'text-red-400':'text-casino-cream');

  // Edge bar
  const bar=document.getElementById('edge-bar');
  const clampedEdge=Math.max(-2,Math.min(2,edge));
  const scale=25; // 1% = 25% of bar
  if(clampedEdge>=0){
    bar.style.left='50%';
    bar.style.width=(clampedEdge*scale)+'%';
    bar.style.background='#4ade80';
  } else {
    bar.style.left=(50+clampedEdge*scale)+'%';
    bar.style.width=(-clampedEdge*scale)+'%';
    bar.style.background='#f87171';
  }
}

function updateAll(){
  renderCardGrid();
  updateDashboard();
}

