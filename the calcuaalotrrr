function addSeen(r){
  if(remaining(r)<=0)return;
  seenCards[r]++;
  cardHistory.push(r);
  updateAll();
}
function removeSeen(r){
  if(seenCards[r]<=0)return;
  seenCards[r]--;
  cardHistory.push(-r);
  updateAll();
}
function undoLast(){
  if(cardHistory.length===0)return;
  const last=cardHistory.pop();
  if(last>0)seenCards[last]--;
  else seenCards[-last]++;
  updateAll();
}
function resetShoe(){
  seenCards.fill(0);
  cardHistory=[];
  updateAll();
}

