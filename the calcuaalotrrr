<script>
/* ========================================
   ACTION CONSTANTS
======================================== */
const HIT=0,STAND=1,DOUBLE=2,SPLIT=3,SURRENDER=4,Dh=5,Ds=6,Rh=7,Rs=8,Ph=9,Rp=10;
const ACTION_NAMES=['HIT','STAND','DOUBLE','SPLIT','SURRENDER','Dbl/Hit','Dbl/Stand','Sur/Hit','Sur/Stand','Spl/Hit','Spl/Sur'];
const ACTION_SHORT=['H','S','D','P','R','Dh','Ds','Rh','Rs','Ph','Rp'];
const ACTION_CSS=['bg-red-400/80 text-casino-black','bg-blue-400/80 text-casino-black','bg-yellow-400/80 text-casino-black','bg-emerald-400/80 text-casino-black','bg-orange-400/80 text-casino-black','bg-yellow-400/80 text-casino-black','bg-yellow-400/80 text-casino-black','bg-orange-400/80 text-casino-black','bg-orange-400/80 text-casino-black','bg-emerald-400/80 text-casino-black','bg-orange-400/80 text-casino-black'];

/* ========================================
   BASIC STRATEGY TABLES (S17, DAS, LS)
   Index: dealer 2=0,3=1,4=2,5=3,6=4,7=5,8=6,9=7,10=8,A=9
======================================== */
const HARD=[
  null,null,null,null,
  [HIT,HIT,HIT,HIT,HIT,HIT,HIT,HIT,HIT,HIT],//4
  [HIT,HIT,HIT,HIT,HIT,HIT,HIT,HIT,HIT,HIT],//5
